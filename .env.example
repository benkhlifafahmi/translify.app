# Root .env — used by docker-compose
# Copy to .env and fill in values

# ---- Postgres (your existing instance) ----
# Use host.docker.internal on Linux only if you've added it to docker-compose extra_hosts
# Otherwise use the host's LAN IP or a docker network alias
POSTGRES_DSN=postgresql+asyncpg://translify:CHANGEME@host.docker.internal:5432/translify

# ---- Redis (your existing instance) ----
REDIS_URL=redis://host.docker.internal:6379/0

# ---- MinIO (runs in compose) ----
MINIO_ROOT_USER=translify
MINIO_ROOT_PASSWORD=CHANGEME-long-random-string
MINIO_BUCKET=translify
# Public URL Apache proxies to MinIO (used to mint presigned URLs)
MINIO_PUBLIC_URL=https://translify.app/files
# Internal URL the API uses to talk to MinIO inside the docker network
MINIO_INTERNAL_URL=http://minio:9000

# ---- Auth ----
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=CHANGEME-generate-a-long-random-secret
JWT_LIFETIME_SECONDS=2592000  # 30 days

# ---- LLM / API keys ----
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=
DEEPL_API_KEY=

# ---- App ----
APP_ENV=production
API_PUBLIC_URL=https://translify.app/api
WEB_PUBLIC_URL=https://translify.app
CORS_ORIGINS=https://translify.app
