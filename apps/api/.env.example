# API .env — copy to .env for local dev (compose uses the root .env)

APP_ENV=development
API_PUBLIC_URL=http://localhost:8000
WEB_PUBLIC_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

POSTGRES_DSN=postgresql+asyncpg://translify:translify@localhost:5432/translify

REDIS_URL=redis://localhost:6379/0

MINIO_ROOT_USER=translify
MINIO_ROOT_PASSWORD=translify-dev
MINIO_BUCKET=translify
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_INTERNAL_URL=http://localhost:9000

JWT_SECRET=dev-secret-change-me
JWT_LIFETIME_SECONDS=2592000

ANTHROPIC_API_KEY=
DEEPL_API_KEY=

# IP geolocation for GET /geo (suggests a UI language from the visitor's
# country). Keyless by default; {ip} is substituted with the client IP. Set
# GEOIP_PROVIDER_URL empty to disable IP detection (browser-language only).
# GEOIP_PROVIDER_URL=https://ipwho.is/{ip}
# GEOIP_TIMEOUT_SECONDS=2.5
# GEOIP_CACHE_TTL_SECONDS=604800
